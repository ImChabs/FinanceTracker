#!/bin/sh
set -eu

repo_root=$(git rev-parse --show-toplevel)

if command -v pwsh >/dev/null 2>&1; then
  exec pwsh -NoProfile -ExecutionPolicy Bypass -File "$repo_root/scripts/git/run-pre-commit.ps1"
fi

if command -v powershell >/dev/null 2>&1; then
  exec powershell -NoProfile -ExecutionPolicy Bypass -File "$repo_root/scripts/git/run-pre-commit.ps1"
fi

exec sh "$repo_root/scripts/git/run-pre-commit.sh"
